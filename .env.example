APP_NAME=LC Admin API
ENVIRONMENT=development
API_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5174"]
ADMIN_API_TOKEN=change-me-admin-token
ADMIN_AUTH_EMAIL=admin@legacycards.local
ADMIN_AUTH_PASSWORD_HASH=
ADMIN_AUTH_JWT_SECRET=
ADMIN_AUTH_JWT_ALGORITHM=HS256
ADMIN_AUTH_JWT_EXPIRES_MINUTES=480
ADMIN_AUTH_2FA_ENABLED=true
ADMIN_AUTH_TOTP_SECRET=
ADMIN_AUTH_TOTP_ISSUER=Legacy Cards Admin
ADMIN_AUTH_2FA_CHALLENGE_MINUTES=5
ADMIN_AUTH_MAX_FAILED_ATTEMPTS=5
ADMIN_AUTH_FAILED_WINDOW_SECONDS=900
FIRESTORE_ENABLED=true
FIRESTORE_PROJECT_ID=
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_COLLECTION_PRODUCTS=store_products
FIRESTORE_COLLECTION_ANALYTICS=analytics_events
FIRESTORE_SERVICE_ACCOUNT_PATH=service.json
BIGQUERY_ENABLED=false
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=legacy_cards_analytics
BIGQUERY_EVENTS_TABLE=events
BIGQUERY_SERVICE_ACCOUNT_PATH=service.json
BIGQUERY_LOCATION=US
BIGQUERY_AUTO_CREATE_DATASET=true
ANALYTICS_SUMMARY_FALLBACK_FIRESTORE=true
POKEMON_TCG_API_BASE_URL=https://api.pokemontcg.io/v2
POKEMON_TCG_API_KEY=
POKEMON_TCG_TIMEOUT_SECONDS=20
POKEMON_TCG_RETRY_ATTEMPTS=4
POKEMON_TCG_RETRY_BASE_DELAY_SECONDS=0.6
POKEMON_TCG_RETRY_MAX_DELAY_SECONDS=6
POKEMON_TCG_MIN_INTERVAL_SECONDS=0.25
AWESOMEAPI_FX_URL=https://economia.awesomeapi.com.br/json/last/USD-BRL,EUR-BRL
AWESOMEAPI_FX_KEY=
AWESOMEAPI_FX_TIMEOUT_SECONDS=8
AWESOMEAPI_FX_CACHE_SECONDS=900
OPENAI_API_KEY=
OPENAI_REGULATION_MODEL=gpt-5-nano
OPENAI_REGULATION_BATCH_SIZE=40
LOT_IMPORT_MAX_CARDS=500
